# PostgreSQL (取证模块专用)
POSTGRES_URL=postgresql://waf_user:waf_password@localhost:5432/waf_incident

# Storage
PCAP_STORAGE_DIR=./storage/pcap

# Forensics
TSHARK_BIN=tshark
DEFAULT_CAPTURE_WINDOW_MINUTES=5

# LLM（signature 目录暂不使用）
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=waf-mvp-analyzer
LLM_TIMEOUT_MS=15000