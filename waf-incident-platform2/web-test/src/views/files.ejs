<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>文件查看</h1>

      <form method="get" action="/files" class="card">
        <label>文件名</label>
        <input name="name" value="<%= name %>" placeholder="welcome.txt" />
        <button type="submit">读取</button>
      </form>

      <section class="card">
        <h2>可用文件</h2>
        <ul>
          <% files.forEach(function(file) { %>
          <li><a href="/files?name=<%= file %>"><%= file %></a></li>
          <% }) %>
        </ul>
      </section>

      <% if (readError) { %>
      <section class="card danger">
        <h2>读取失败</h2>
        <p><%= readError %></p>
      </section>
      <% } %>

      <% if (content) { %>
      <section class="card">
        <h2>文件内容</h2>
        <pre><%= content %></pre>
      </section>
      <% } %>

      <p><a href="/">返回首页</a></p>
    </main>
  </body>
</html>
