<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Attack Lab</h1>
      <p>下面 3 类输入可用于触发常见规则集检测。</p>

      <section class="card">
        <h2>1. SQL 注入（POST /api/auth/login）</h2>
        <form method="post" action="/api/auth/login">
          <label>username</label>
          <input name="username" value="admin' OR '1'='1" />
          <label>password</label>
          <input name="password" value="anything" />
          <button type="submit">提交</button>
        </form>
      </section>

      <section class="card">
        <h2>2. 反射型 XSS（GET /search）</h2>
        <form method="get" action="/search">
          <label>q</label>
          <input name="q" value="<script>alert('xss')</script>" />
          <button type="submit">搜索</button>
        </form>
      </section>

      <section class="card">
        <h2>3. 命令注入探测（POST /api/tools/ping-preview）</h2>
        <form method="post" action="/api/tools/ping-preview">
          <label>host</label>
          <input name="host" value="8.8.8.8;cat /etc/passwd" />
          <button type="submit">预览命令</button>
        </form>
      </section>

      <section class="card">
        <h2>附加：路径穿越探测（GET /legacy/download）</h2>
        <p><a href="/legacy/download?name=../../etc/passwd">/legacy/download?name=../../etc/passwd</a></p>
      </section>

      <p><a href="/">返回首页</a></p>
    </main>
  </body>
</html>
