<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="card">
        <h1>夜航日志</h1>
        <p>一个无业务交易能力的内容网站，提供文章、检索与公开资料下载。</p>
        <nav class="top-nav">
          <a href="/">首页</a>
          <a href="/about">关于</a>
          <a href="/articles">文章</a>
          <a href="/search?q=waf">搜索</a>
          <a href="/files">资料下载</a>
        </nav>
      </header>

      <section class="card">
        <h2>最新文章</h2>
        <ul>
          <% articles.forEach(function(article) { %>
          <li>
            <a href="/articles/<%= article.slug %>"><%= article.title %></a>
            <p><%= article.summary %></p>
          </li>
          <% }) %>
        </ul>
      </section>

      <section class="card">
        <h2>站点说明</h2>
        <p>本站用于规则联调与安全演练，不提供注册、下单、支付等业务行为。</p>
        <p><a href="/attack-lab">安全演练入口</a></p>
      </section>
    </main>
  </body>
</html>
