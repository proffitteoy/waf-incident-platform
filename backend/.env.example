# ===== 必填（启动后端前请先确认） =====

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=waf_incident
POSTGRES_USER=waf_user
POSTGRES_PASSWORD=waf_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=waf:mvp

# Backend
BACKEND_PORT=3000
JWT_SECRET=replace-this-secret

# WAF 上游（目标防御网站）
WEBSITE_URL=http://host.docker.internal:8080

# 取证下载签名密钥（至少16位）
FORENSICS_DOWNLOAD_SIGNING_SECRET=change-this-forensics-secret

# ===== 可选（不改也能启动，按需调整） =====

# LLM
# LLM_API_URL=https://your-llm-api.example.com/v1/analyze
LLM_API_KEY=
LLM_MODEL=waf-mvp-analyzer
LLM_MODEL_VERSION=default
LLM_TASK_NAME=waf_incident_analysis_mvp
LLM_PROMPT_VERSION=v1
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=250
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_MS=30000
LLM_FALLBACK_MODE=deterministic

# Storage
LOG_ARCHIVE_DIR=./storage/logs
PCAP_DIR=./storage/pcap
REPORT_DIR=./storage/reports

# Forensics
TSHARK_BIN=tshark
DEFAULT_CAPTURE_WINDOW_MINUTES=5
BACKEND_API_URL=http://localhost:3000
FORENSICS_PYTHON_BIN=python3
FORENSICS_DOWNLOAD_TOKEN_REQUIRED=false
FORENSICS_DOWNLOAD_URL_TTL_SECONDS=300
