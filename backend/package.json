{
  "name": "waf-incident-backend",
  "version": "0.1.0",
  "private": true,
  "description": "MVP backend for WAF incident lifecycle",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker:ingestion": "ts-node-dev --transpile-only src/services/ingestion/audit-tail.worker.ts",
    "test": "jest --runInBand --config jest.config.cjs",
    "test:unit": "jest --runInBand --config jest.config.cjs ../test/backend/unit",
    "test:module": "jest --runInBand --config jest.config.cjs ../test/backend/module",
    "test:integration": "jest --runInBand --config jest.config.cjs ../test/backend/integration",
    "test:workflow": "jest --runInBand --config jest.config.cjs ../test/backend/workflow",
    "test:e2e": "set RUN_GATEWAY_E2E=true&& jest --runInBand --config jest.config.cjs ../test/backend/e2e"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
